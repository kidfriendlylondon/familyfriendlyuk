# Mapbox public token — get yours at https://account.mapbox.com/access-tokens/
# Add this to Vercel environment variables as PUBLIC_MAPBOX_TOKEN
PUBLIC_MAPBOX_TOKEN=pk.your_mapbox_token_here

# Formspree form ID — create a form at https://formspree.io
PUBLIC_FORMSPREE_ID=your_formspree_id_here

# Mailchimp — optional, for email capture
PUBLIC_MAILCHIMP_URL=your_mailchimp_form_url_here
