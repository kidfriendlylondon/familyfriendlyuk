---
import type { Restaurant } from '../data/restaurants';
import AttributeBadges from './AttributeBadges.astro';

interface Props {
  restaurant: Restaurant;
  featured?: boolean;
}
const { restaurant: r, featured = false } = Astro.props;

const heroImage = r.photos[0];
const stars = '★'.repeat(Math.round(r.googleRating)) + '☆'.repeat(5 - Math.round(r.googleRating));
const priceMap: Record<string, string> = { '£': '£', '££': '££', '$$$': '£££' };
---

<article class:list={['restaurant-card card', { 'restaurant-card--featured': r.featured || featured }]}>
  <a href={`/restaurants/${r.slug}`} class="card-image-link" aria-label={r.name} tabindex="-1">
    <div class="card-image">
      {heroImage ? (
        <img src={heroImage} alt={r.name} width="400" height="260" loading="lazy" />
      ) : (
        <div class="card-image-placeholder" aria-hidden="true">
          <span>{r.cuisineType.split('/')[0].trim()}</span>
        </div>
      )}
      {r.featured && <span class="featured-badge">Featured</span>}
      <span class="price-overlay">{priceMap[r.priceRange]}</span>
    </div>
  </a>

  <div class="card-body">
    <div class="card-meta">
      <span class="cuisine">{r.cuisineType}</span>
      <span class="area">{r.area}</span>
    </div>

    <h3 class="card-title">
      <a href={`/restaurants/${r.slug}`}>{r.name}</a>
    </h3>

    <p class="card-desc">{r.shortDescription}</p>

    <AttributeBadges restaurant={r} compact />

    <div class="card-footer">
      <div class="stars" aria-label={`Rated ${r.googleRating} out of 5`}>
        {stars}
        <span>{r.googleRating} ({r.reviewCount.toLocaleString()})</span>
      </div>
      <a href={`/restaurants/${r.slug}`} class="card-cta">
        View details →
      </a>
    </div>
  </div>
</article>

<style>
.restaurant-card { display: flex; flex-direction: column; height: 100%; }
.restaurant-card--featured { border: 2px solid var(--terracotta); }
.card-image-link { display: block; }
.card-image {
  position: relative;
  height: 200px;
  overflow: hidden;
  background: var(--green-pale);
}
.card-image img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.3s ease;
}
.restaurant-card:hover .card-image img { transform: scale(1.03); }
.card-image-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, var(--green-pale) 0%, #dce8cc 100%);
}
.card-image-placeholder span {
  font-family: var(--font-serif);
  font-size: 1rem;
  color: var(--green);
  text-align: center;
  padding: 20px;
}
.featured-badge {
  position: absolute;
  top: 12px;
  left: 12px;
  background: var(--terracotta);
  color: white;
  font-size: 0.75rem;
  font-weight: 600;
  padding: 4px 10px;
  border-radius: 20px;
  letter-spacing: 0.04em;
  text-transform: uppercase;
}
.price-overlay {
  position: absolute;
  bottom: 12px;
  right: 12px;
  background: rgba(255,255,255,0.92);
  color: var(--text-muted);
  font-size: 0.8125rem;
  font-weight: 700;
  padding: 3px 10px;
  border-radius: 20px;
  letter-spacing: 0.03em;
}
.card-body {
  padding: 20px;
  display: flex;
  flex-direction: column;
  gap: 10px;
  flex: 1;
}
.card-meta {
  display: flex;
  gap: 8px;
  align-items: center;
  flex-wrap: wrap;
}
.cuisine {
  font-size: 0.8125rem;
  color: var(--terracotta);
  font-weight: 500;
}
.area {
  font-size: 0.8125rem;
  color: var(--text-muted);
}
.area::before { content: '· '; }
.card-title {
  font-family: var(--font-serif);
  font-size: 1.175rem;
  line-height: 1.3;
  margin: 0;
}
.card-title a { color: var(--text); }
.card-title a:hover { color: var(--green); }
.card-desc {
  font-size: 0.9rem;
  color: var(--text-muted);
  line-height: 1.6;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}
.card-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: auto;
  padding-top: 12px;
  border-top: 1px solid var(--border);
}
.card-cta {
  font-size: 0.875rem;
  color: var(--green);
  font-weight: 500;
  transition: color 0.15s;
}
.card-cta:hover { color: var(--terracotta); }
</style>
