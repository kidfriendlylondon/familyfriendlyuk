---
import BaseLayout from '../../layouts/BaseLayout.astro';
import RestaurantCard from '../../components/RestaurantCard.astro';
import { restaurants, getNearby } from '../../data/restaurants';

// SSR + ISR. Pre-rendering 35k+ static pages was timing out the
// Vercel build; this route is now rendered on-demand at the edge and
// cached for 1 hour (configured via the Vercel adapter's `isr`
// option in astro.config.mjs).
export const prerender = false;

const { slug } = Astro.params as { slug: string };
const r = restaurants.find(x => x.slug === slug);

if (!r) {
  return new Response('Restaurant not found', { status: 404 });
}

// Tell Vercel's edge to cache this rendered page for 1 hour, with up
// to a day of stale-while-revalidate so users never wait on a refresh.
Astro.response.headers.set(
  'Cache-Control',
  'public, max-age=0, s-maxage=3600, stale-while-revalidate=86400'
);

const related = getNearby(r.lat, r.lng, 3, r.slug);
const days = ['Monday','Tuesday','Wednesday','Thursday','Friday','Saturday','Sunday'];

const siteUrl = 'https://familyfriendlyuk.co.uk';
const listingUrl = `${siteUrl}/restaurants/${r.slug}`;

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Restaurant',
  name: r.name,
  description: r.shortDescription,
  address: {
    '@type': 'PostalAddress',
    streetAddress: r.address,
    addressLocality: r.area,
    addressRegion: r.city,
    postalCode: r.postcode,
    addressCountry: 'GB',
  },
  ...(r.phone && { telephone: r.phone }),
  ...(r.website && { url: r.website }),
  ...(r.lat && r.lng && {
    geo: { '@type': 'GeoCoordinates', latitude: r.lat, longitude: r.lng },
  }),
  aggregateRating: {
    '@type': 'AggregateRating',
    ratingValue: r.googleRating,
    reviewCount: r.reviewCount,
    bestRating: 5,
    worstRating: 1,
  },
  priceRange: r.priceRange,
  servesCuisine: r.cuisineType,
  openingHoursSpecification: Object.entries(r.openingHours)
    .filter(([, hours]) => hours && hours !== 'Closed')
    .map(([day, hours]) => ({
      '@type': 'OpeningHoursSpecification',
      dayOfWeek: `https://schema.org/${day}`,
      opens: hours.split('–')[0]?.split(', ')[0] ?? '',
      closes: hours.split('–').pop()?.split(', ')[0] ?? '',
    })),
  amenityFeature: [
    r.kidsMenu === 'yes' && { '@type': 'LocationFeatureSpecification', name: "Children's Menu", value: true },
    r.highchairs === 'yes' && { '@type': 'LocationFeatureSpecification', name: 'High Chairs', value: true },
    r.outdoorSpace === 'yes' && { '@type': 'LocationFeatureSpecification', name: 'Outdoor Seating', value: true },
    r.babyChanging === 'yes' && { '@type': 'LocationFeatureSpecification', name: 'Baby Changing Facilities', value: true },
  ].filter(Boolean),
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: siteUrl },
    { '@type': 'ListItem', position: 2, name: 'Browse cities', item: `${siteUrl}/regions` },
    { '@type': 'ListItem', position: 3, name: r.area, item: `${siteUrl}/area/${r.areaSlug}` },
    { '@type': 'ListItem', position: 4, name: r.name, item: listingUrl },
  ],
};

function attrStatus(val: string | undefined) {
  if (val === 'yes') return { cls: 'attribute-item--yes', icon: '✅', label: 'Yes' };
  if (val === 'no') return { cls: 'attribute-item--no', icon: '❌', label: 'No' };
  return { cls: 'attribute-item--likely', icon: '🟡', label: 'Likely' };
}

function softPlayValue(): { cls: string; icon: string; label: string } {
  if (r.softPlay === 'yes' && r.softPlayName) {
    return { cls: 'attribute-item--yes', icon: '✅', label: `Yes — ${r.softPlayName}` };
  }
  return attrStatus(r.softPlay);
}

const noiseLabel = r.noiseLevel.charAt(0).toUpperCase() + r.noiseLevel.slice(1);
const bookingLabel = r.bookingRequired === 'yes'
  ? 'Required'
  : r.bookingRequired === 'recommended' ? 'Recommended' : 'Walk-ins welcome';
const bestForLabel = r.bestForAgeRange.length
  ? r.bestForAgeRange.map(a => a.charAt(0).toUpperCase() + a.slice(1)).join(', ')
  : 'All ages';
---

<BaseLayout
  title={`${r.name} — Family Friendly Restaurant in ${r.area} | Family Friendly UK`}
  description={`${r.shortDescription} ${r.name} in ${r.area}, ${r.city}. ${r.googleRating}★ on Google from ${r.reviewCount.toLocaleString()} reviews.`}
  ogImage={r.photos[0]}
  schema={[schema, breadcrumbSchema]}
>
  {/* Full-width hero photo */}
  {r.photos.length > 0 ? (
    <img
      src={r.photos[0]}
      alt={`${r.name} — ${r.area}`}
      class="listing-hero-photo"
      loading="eager"
    />
  ) : (
    <div class="listing-hero-placeholder">🌿</div>
  )}

  <div class="listing-detail">
    <div class="container">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/">Home</a>
        <span>›</span>
        <a href="/regions">Browse cities</a>
        <span>›</span>
        <a href={`/area/${r.areaSlug}`}>{r.area}</a>
        <span>›</span>
        <span>{r.name}</span>
      </nav>

      <div class="listing-detail__grid">
        {/* Main content */}
        <div>
          {/* Header */}
          <div style="margin-bottom:1.75rem">
            {r.featured && (
              <span class="badge-featured" style="position:static;display:inline-block;margin-bottom:0.75rem;background:var(--terracotta);color:white;font-size:0.7rem;font-weight:600;padding:4px 10px;border-radius:20px;letter-spacing:0.04em;text-transform:uppercase">
                ⭐ Featured Restaurant
              </span>
            )}
            <p style="font-size:0.78rem;font-weight:600;text-transform:uppercase;letter-spacing:0.08em;color:var(--terracotta);margin-bottom:0.4rem">
              {r.cuisineType} · {r.area}
            </p>
            <h1 style="font-family:var(--font-serif);font-size:clamp(1.75rem,4vw,2.5rem);color:var(--text);margin-bottom:0.75rem;line-height:1.15">{r.name}</h1>
            <div style="display:flex;align-items:center;gap:1rem;flex-wrap:wrap;margin-bottom:1rem">
              <div class="rating">
                <span class="rating__star">★</span>
                <strong>{r.googleRating}</strong>
                <span class="rating__count">({r.reviewCount.toLocaleString()} reviews)</span>
              </div>
              <span class="price-range">{r.priceRange}</span>
              <span style="font-size:0.875rem;color:var(--text-muted)">📍 {r.address}</span>
            </div>
          </div>

          {/* Additional photos */}
          {r.photos.length > 1 && (
            <div class="listing-detail__photos">
              {r.photos.slice(1, 3).map((src, i) => (
                <img
                  src={src}
                  alt={`${r.name} — photo ${i + 2}`}
                  loading="lazy"
                  style="height:240px;object-fit:cover;width:100%"
                />
              ))}
            </div>
          )}

          {/* Description */}
          <div class="listing-detail__section">
            <h2>About {r.name}</h2>
            <p style="font-size:1rem;line-height:1.7;color:var(--text)">{r.description}</p>
          </div>

          {/* Kid-friendly attributes */}
          <div class="listing-detail__section">
            <h2>Kid-friendly features</h2>
            <div class="attribute-grid">
              {[
                { val: r.kidsMenu, label: 'Kids menu', icon: '🍽️' },
                { val: r.highchairs, label: 'Highchairs', icon: '🪑' },
                { val: r.outdoorSpace, label: 'Outdoor space', icon: '🌿' },
                { val: r.babyChanging, label: 'Baby changing', icon: '🚿' },
                { val: r.buggyAccessible, label: 'Buggy accessible', icon: '🛻' },
                { val: r.veganOptions, label: 'Vegan options', icon: '🌱' },
                { val: r.glutenFreeOptions, label: 'Gluten free', icon: '🌾' },
                { val: r.halalOptions, label: 'Halal', icon: '☪️' },
              ].map(({ val, label, icon }) => {
                const { cls, icon: stIcon, label: stLabel } = attrStatus(val);
                return (
                  <div class={`attribute-item ${cls}`}>
                    <span class="attribute-item__icon">{icon}</span>
                    <div>
                      <span class="attribute-item__label">{label}</span>
                      <span class="attribute-item__value">{stIcon} {stLabel}</span>
                    </div>
                  </div>
                );
              })}
              {/* Soft play has its own renderer to surface softPlayName */}
              {(() => {
                const sp = softPlayValue();
                return (
                  <div class={`attribute-item ${sp.cls}`}>
                    <span class="attribute-item__icon">🎠</span>
                    <div>
                      <span class="attribute-item__label">Soft play area</span>
                      <span class="attribute-item__value">{sp.icon} {sp.label}</span>
                    </div>
                  </div>
                );
              })()}
              <div class="attribute-item">
                <span class="attribute-item__icon">🔊</span>
                <div>
                  <span class="attribute-item__label">Noise level</span>
                  <span class="attribute-item__value">{noiseLabel}</span>
                </div>
              </div>
              <div class="attribute-item">
                <span class="attribute-item__icon">📅</span>
                <div>
                  <span class="attribute-item__label">Booking</span>
                  <span class="attribute-item__value">{bookingLabel}</span>
                </div>
              </div>
              <div class="attribute-item">
                <span class="attribute-item__icon">👶</span>
                <div>
                  <span class="attribute-item__label">Best for</span>
                  <span class="attribute-item__value">{bestForLabel}</span>
                </div>
              </div>
            </div>
          </div>

          {/* Tags */}
          {r.tags.length > 0 && (
            <div class="listing-detail__section">
              <h2>Tags</h2>
              <div class="attribute-tags">
                {r.tags.map((tag) => (
                  <span class="attr-tag">#{tag.replace(/-/g, ' ')}</span>
                ))}
              </div>
            </div>
          )}

          {/* Suggest edit */}
          <div style="padding:1rem 1.25rem;background:var(--cream);border-radius:var(--radius-sm);border:1px solid var(--border);font-size:0.875rem;color:var(--text-muted)">
            Something wrong or out of date?
            <a href={`/suggest?restaurant=${encodeURIComponent(r.name)}`} style="color:var(--terracotta);font-weight:500;text-decoration:underline">
              Suggest an edit →
            </a>
          </div>

          {/* Related listings */}
          {related.length > 0 && (
            <div class="listing-detail__section" style="margin-top:3rem">
              <h2>You might also like</h2>
              <div class="grid-3">
                {related.map((rel) => <RestaurantCard restaurant={rel} />)}
              </div>
            </div>
          )}
        </div>

        {/* Sidebar */}
        <aside class="listing-sidebar">
          {/* Booking */}
          <div class="sidebar-card">
            <h3>Booking</h3>
            <p style="font-size:0.875rem;color:var(--text-muted);margin-bottom:1rem">
              {r.bookingRequired === 'yes'
                ? 'Booking is required for this restaurant. Call or visit their website.'
                : r.bookingRequired === 'recommended'
                  ? 'Booking is recommended, especially on weekends.'
                  : 'Walk-ins are welcome — no booking needed.'}
            </p>
            {r.phone && (
              <a href={`tel:${r.phone}`} class="btn btn-secondary booking-btn">
                📞 {r.phone}
              </a>
            )}
            {r.website && (
              <a href={r.website} class="btn btn-secondary booking-btn" target="_blank" rel="noopener">
                🌐 Visit website
              </a>
            )}
          </div>

          {/* Details */}
          <div class="sidebar-card">
            <h3>Details</h3>
            <table class="hours-table">
              <tbody>
                <tr><td>Address</td><td>{r.address}, {r.postcode}</td></tr>
                <tr><td>Cuisine</td><td>{r.cuisineType}</td></tr>
                <tr><td>Price range</td><td>{r.priceRange}</td></tr>
                <tr><td>Area</td><td><a href={`/area/${r.areaSlug}`} style="color:var(--terracotta)">{r.area}</a></td></tr>
              </tbody>
            </table>
          </div>

          {/* Opening hours */}
          <div class="sidebar-card">
            <h3>Opening hours</h3>
            <table class="hours-table">
              <tbody>
                {days.map((day) => (
                  <tr>
                    <td>{day.slice(0, 3)}</td>
                    <td style={r.openingHours[day] === 'Closed' ? 'color:var(--text-muted)' : ''}>
                      {r.openingHours[day] || '—'}
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>

          {/* Map */}
          {r.lat && r.lng && (
            <div class="sidebar-card">
              <h3>Location</h3>
              <a
                href={`https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(r.name + ' ' + r.address)}`}
                class="btn btn-secondary booking-btn"
                target="_blank"
                rel="noopener"
              >
                Open in Google Maps →
              </a>
            </div>
          )}
        </aside>
      </div>
    </div>
  </div>
</BaseLayout>
