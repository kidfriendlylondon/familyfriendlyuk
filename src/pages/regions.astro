---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getAreaStats } from '../data/restaurants';

const areaStats = getAreaStats();
const topCities = Object.entries(areaStats)
  .sort((a, b) => b[1].count - a[1].count)
  .slice(0, 25);

const schema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://familyfriendlyuk.co.uk" },
    { "@type": "ListItem", "position": 2, "name": "Browse Cities", "item": "https://familyfriendlyuk.co.uk/regions" }
  ]
};
---

<BaseLayout
  title="Browse Family-Friendly Restaurants by City | Family Friendly UK"
  description="Browse family-friendly restaurants across the UK's top cities — London, Manchester, Edinburgh, Bristol, Birmingham and more. Find great places to eat with children near you."
  schema={schema}
>
  <div class="page-hero">
    <div class="container">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/">Home</a>
        <span class="sep" aria-hidden="true">›</span>
        <span aria-current="page">Browse cities</span>
      </nav>
      <h1>Browse family-friendly restaurants by city</h1>
      <p>The top 25 UK cities and towns by number of family-friendly listings.</p>
    </div>
  </div>

  <section>
    <div class="container">
      <div class="cities-grid">
        {topCities.map(([slug, stat]) => (
          <a href={`/area/${slug}`} class="city-card card">
            <div class="city-card-body">
              <div class="city-card-icon" aria-hidden="true">📍</div>
              <div>
                <h3>{stat.name}</h3>
                <p class="city-count">{stat.count.toLocaleString()} restaurant{stat.count !== 1 ? 's' : ''}</p>
              </div>
            </div>
            <span class="city-arrow">Browse →</span>
          </a>
        ))}
      </div>

      <div class="suggest-cta">
        <div class="suggest-cta-inner">
          <h2>Don't see your city?</h2>
          <p>We're adding listings all the time. Tell us about a great family restaurant near you.</p>
          <a href="/suggest" class="btn btn-terracotta btn-lg">Suggest a restaurant</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
.cities-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
  gap: 16px;
}
.city-card {
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  gap: 12px;
  padding: 24px;
  transition: transform 0.15s, border-color 0.15s, background 0.15s;
}
.city-card:hover {
  border-color: var(--green);
  background: var(--green-pale);
  transform: translateY(-2px);
}
.city-card-body { display: flex; gap: 16px; align-items: flex-start; }
.city-card-icon { font-size: 1.75rem; flex-shrink: 0; }
.city-card h3 { font-family: var(--font-serif); font-size: 1.2rem; margin-bottom: 4px; }
.city-count { font-size: 0.9375rem; color: var(--text-muted); }
.city-arrow {
  font-size: 0.9rem;
  color: var(--green);
  font-weight: 500;
  align-self: flex-end;
}
.suggest-cta {
  margin-top: 56px;
  background: var(--green);
  border-radius: var(--radius);
  padding: 48px;
  text-align: center;
}
.suggest-cta-inner { max-width: 540px; margin: 0 auto; }
.suggest-cta h2 { color: white; margin-bottom: 12px; }
.suggest-cta p { color: rgba(255,255,255,0.78); font-size: 1.0625rem; margin-bottom: 24px; }
</style>
