---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getAreaStats } from '../data/restaurants';

const areaStats = getAreaStats();
const areas = Object.entries(areaStats)
  .sort((a, b) => a[1].name.localeCompare(b[1].name));

const schema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://familyfriendlyuk.co.uk" },
    { "@type": "ListItem", "position": 2, "name": "All Regions", "item": "https://familyfriendlyuk.co.uk/regions" }
  ]
};
---

<BaseLayout
  title="Family Friendly Restaurants by Region | Family Friendly UK"
  description="Browse family-friendly restaurants by region across the UK. From London neighbourhoods to cities across Britain — find great places to eat with children near you."
  schema={schema}
>
  <div class="page-hero">
    <div class="container">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/">Home</a>
        <span class="sep" aria-hidden="true">›</span>
        <span aria-current="page">All regions</span>
      </nav>
      <h1>Family restaurants by region</h1>
      <p>We've started with London and we're adding UK cities all the time. Know a great family restaurant somewhere we don't cover yet? <a href="/suggest" style="color:white;text-decoration:underline">Tell us about it.</a></p>
    </div>
  </div>

  <section>
    <div class="container">
      <div class="regions-intro">
        <p>Currently covering <strong>{areas.length} areas</strong> across the UK, with <strong>more cities coming soon</strong>.</p>
      </div>

      <h2 class="regions-group-title">London</h2>
      <div class="regions-grid">
        {areas.filter(([, s]) => s.citySlug === 'london').map(([slug, stat]) => (
          <a href={`/area/${slug}`} class="region-card card">
            <div class="region-card-body">
              <div class="region-card-icon" aria-hidden="true">📍</div>
              <div>
                <h3>{stat.name}</h3>
                <p class="region-count">{stat.count} restaurant{stat.count !== 1 ? 's' : ''}</p>
                <p class="region-sub">
                  {stat.featured.length > 0 && `Includes ${stat.featured.length} featured pick${stat.featured.length !== 1 ? 's' : ''}`}
                </p>
              </div>
            </div>
            <span class="region-arrow">Browse →</span>
          </a>
        ))}
      </div>

      <h2 class="regions-group-title" style="margin-top:56px">Coming soon</h2>
      <div class="regions-grid">
        {[
          { name: 'Manchester', slug: 'manchester', note: 'Opening listings soon' },
          { name: 'Edinburgh', slug: 'edinburgh', note: 'Opening listings soon' },
          { name: 'Bristol', slug: 'bristol', note: 'Opening listings soon' },
          { name: 'Birmingham', slug: 'birmingham', note: 'Opening listings soon' },
          { name: 'Leeds', slug: 'leeds', note: 'Opening listings soon' },
          { name: 'Brighton', slug: 'brighton', note: 'Opening listings soon' },
          { name: 'Bath', slug: 'bath', note: 'Opening listings soon' },
          { name: 'Oxford', slug: 'oxford', note: 'Opening listings soon' },
        ].map(city => (
          <div class="region-card card region-card--soon">
            <div class="region-card-body">
              <div class="region-card-icon" aria-hidden="true">🏙️</div>
              <div>
                <h3>{city.name}</h3>
                <p class="region-count">{city.note}</p>
              </div>
            </div>
            <a href="/suggest" class="region-suggest">Suggest a restaurant →</a>
          </div>
        ))}
      </div>

      <div class="suggest-cta">
        <div class="suggest-cta-inner">
          <h2>Know a great family restaurant?</h2>
          <p>Help us build the UK's most useful family restaurant guide. Every suggestion is reviewed by the team.</p>
          <a href="/suggest" class="btn btn-terracotta btn-lg">Suggest a restaurant</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
.regions-intro {
  font-size: 1.0625rem;
  color: var(--text-muted);
  margin-bottom: 40px;
  padding: 20px 24px;
  background: var(--green-pale);
  border-radius: var(--radius-sm);
  border-left: 3px solid var(--green);
}
.regions-intro strong { color: var(--green); }
.regions-group-title {
  font-family: var(--font-serif);
  font-size: 1.5rem;
  color: var(--text);
  margin-bottom: 24px;
  padding-bottom: 12px;
  border-bottom: 1px solid var(--border);
}
.regions-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
  gap: 16px;
}
.region-card {
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  gap: 12px;
  padding: 24px;
}
.region-card--soon { opacity: 0.65; }
.region-card-body { display: flex; gap: 16px; align-items: flex-start; }
.region-card-icon { font-size: 1.75rem; flex-shrink: 0; }
.region-card h3 { font-family: var(--font-serif); font-size: 1.2rem; margin-bottom: 4px; }
.region-count { font-size: 0.9375rem; color: var(--text-muted); }
.region-sub { font-size: 0.8125rem; color: var(--terracotta); margin-top: 2px; }
.region-arrow {
  font-size: 0.9rem;
  color: var(--green);
  font-weight: 500;
  align-self: flex-end;
}
.region-suggest {
  font-size: 0.875rem;
  color: var(--terracotta);
  text-decoration: underline;
  align-self: flex-end;
}
.suggest-cta {
  margin-top: 56px;
  background: var(--green);
  border-radius: var(--radius);
  padding: 48px;
  text-align: center;
}
.suggest-cta-inner { max-width: 540px; margin: 0 auto; }
.suggest-cta h2 { color: white; margin-bottom: 12px; }
.suggest-cta p { color: rgba(255,255,255,0.78); font-size: 1.0625rem; margin-bottom: 24px; }
</style>
