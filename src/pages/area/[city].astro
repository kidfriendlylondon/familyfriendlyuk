---
import BaseLayout from '../../layouts/BaseLayout.astro';
import RestaurantCard from '../../components/RestaurantCard.astro';
import EmailCapture from '../../components/EmailCapture.astro';
import CityMap from '../../components/CityMap.tsx';
import { restaurants, getAreaStats } from '../../data/restaurants';

export async function getStaticPaths() {
  const areaStats = getAreaStats();
  return Object.keys(areaStats).map(areaSlug => ({ params: { city: areaSlug } }));
}

const { city } = Astro.params as { city: string };
const areaStats = getAreaStats();
const stat = areaStats[city];

if (!stat) {
  return Astro.redirect('/regions');
}

// Quality bar: hide listings where the three core family-friendly features
// (kids menu, highchairs, buggy access) are *all* unconfirmed — i.e. each
// is either "no" or "likely". A single confirmed "yes" on any of those is
// enough to keep the listing. This mirrors the rule applied to the map
// (CityMap.tsx) so cards and pins always match.
const allAreaListings = restaurants.filter(r => r.areaSlug === city);
const areaRestaurants = allAreaListings.filter(r =>
  r.kidsMenu === 'yes' || r.highchairs === 'yes' || r.buggyAccessible === 'yes'
);
const hiddenLowConfidenceCount = allAreaListings.length - areaRestaurants.length;
const areaName = stat.name;
const cityName = stat.citySlug === 'london' ? 'London' : areaName;

const schema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://familyfriendlyuk.co.uk" },
    { "@type": "ListItem", "position": 2, "name": "Browse Cities", "item": "https://familyfriendlyuk.co.uk/regions" },
    { "@type": "ListItem", "position": 3, "name": `Family Friendly Restaurants in ${areaName}`, "item": `https://familyfriendlyuk.co.uk/area/${city}` }
  ]
};
---

<BaseLayout
  title={`Family Friendly Restaurants in ${areaName}, ${cityName} | Family Friendly UK`}
  description={`The best family-friendly restaurants in ${areaName}, ${cityName}. Highchairs, kids menus, outdoor space — all the things that matter to parents. ${areaRestaurants.length} restaurants reviewed.`}
  schema={schema}
>
  <div class="page-hero">
    <div class="container">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/">Home</a>
        <span class="sep" aria-hidden="true">›</span>
        <a href="/regions">Browse cities</a>
        <span class="sep" aria-hidden="true">›</span>
        <span aria-current="page">{areaName}</span>
      </nav>
      <h1>Family friendly restaurants in {areaName}</h1>
      <p>
        {areaRestaurants.length} reviewed restaurant{areaRestaurants.length !== 1 ? 's' : ''} across {areaName}.
        Every listing is checked for the things that actually matter: highchairs, kids menus, outdoor space, and a genuine welcome for families.
      </p>
    </div>
  </div>

  <section>
    <div class="container">
      {areaRestaurants.length > 0 ? (
        <>
          <div class="city-map-section">
            <CityMap areaSlug={city} areaName={areaName} client:load />
          </div>

          <div class="grid-3 listings-grid" id="city-listings">
            {areaRestaurants.map(r => (
              <div
                class="listing-wrapper"
                data-kids-menu={r.kidsMenu}
                data-highchairs={r.highchairs}
                data-buggy={r.buggyAccessible}
                data-soft-play={r.softPlay}
                data-outdoor={r.outdoorSpace}
                data-baby-changing={r.babyChanging}
                data-vegan={r.veganOptions}
                data-gluten-free={r.glutenFreeOptions}
                data-halal={r.halalOptions}
              >
                <RestaurantCard restaurant={r} />
              </div>
            ))}
          </div>

          <p class="listings-empty" id="listings-empty" hidden>
            No restaurants in {areaName} match those filters. Try removing one or two.
          </p>
        </>
      ) : (
        <div class="empty-state">
          <p>We don't have any listings for {areaName} yet.</p>
          <p>Be the first to suggest a great family restaurant here.</p>
          <a href="/suggest" class="btn btn-terracotta" style="margin-top:16px">Suggest a restaurant</a>
        </div>
      )}

      {areaRestaurants.length < 3 && (
        <div class="suggest-nudge">
          <h3>Know a great family restaurant in {areaName}?</h3>
          <p>We're building this area — help us make it better for families near you.</p>
          <a href="/suggest" class="btn btn-terracotta">Suggest a restaurant →</a>
        </div>
      )}

      <div class="area-email" style="margin-top:48px">
        <EmailCapture
          headline={`Get our guide to family restaurants in ${areaName} and beyond`}
          subline="Download our free PDF guide to the best family restaurants we've reviewed — honest verdicts on every single one."
        />
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  const FILTER_TO_DATA: Record<string, string> = {
    kidsMenu: 'kidsMenu',
    highchairs: 'highchairs',
    buggyFriendly: 'buggy',
    softPlay: 'softPlay',
    outdoorSpace: 'outdoor',
    babyChanging: 'babyChanging',
    vegan: 'vegan',
    glutenFree: 'glutenFree',
    halal: 'halal',
  };

  window.addEventListener('ffuk-city-filters', ((e: CustomEvent) => {
    const filters = e.detail as Record<string, boolean>;
    const wrappers = document.querySelectorAll<HTMLElement>('#city-listings .listing-wrapper');
    let visibleCount = 0;
    wrappers.forEach(el => {
      const matches = Object.entries(filters).every(([key, on]) => {
        if (!on) return true;
        const dataKey = FILTER_TO_DATA[key];
        if (!dataKey) return true;
        return el.dataset[dataKey] === 'yes';
      });
      el.style.display = matches ? '' : 'none';
      if (matches) visibleCount++;
    });
    const empty = document.getElementById('listings-empty');
    if (empty) (empty as HTMLElement).hidden = visibleCount > 0;
  }) as EventListener);
</script>

<style>
.city-map-section { margin-bottom: 36px; }
.listings-grid { margin-bottom: 24px; }
.listings-empty {
  text-align: center;
  padding: 48px 24px;
  color: var(--text-muted);
  font-size: 1rem;
}
.empty-state {
  text-align: center;
  padding: 64px 24px;
  color: var(--text-muted);
}
.suggest-nudge {
  background: var(--terracotta-pale);
  border: 1.5px solid var(--terracotta);
  border-radius: var(--radius);
  padding: 32px;
  display: flex;
  flex-direction: column;
  gap: 10px;
  max-width: 600px;
  margin: 0 auto 40px;
  text-align: center;
}
.suggest-nudge h3 { font-family: var(--font-serif); color: var(--terracotta); }
.suggest-nudge p { color: var(--text-muted); }
</style>
