---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Page Not Found | Family Friendly UK"
  description="The page you were looking for doesn't exist."
>
  <div style="text-align:center;padding:120px 24px">
    <div style="font-size:3rem;margin-bottom:20px">🌿</div>
    <h1 style="font-family:Georgia,serif;margin-bottom:16px">Page not found</h1>
    <p style="color:#6b6457;max-width:480px;margin:0 auto 32px;font-size:1.0625rem;line-height:1.7">
      That page seems to have wandered off. Head back home and find a great family restaurant near you.
    </p>
    <a href="/" class="btn btn-primary btn-lg">Back to the map →</a>
  </div>
</BaseLayout>
